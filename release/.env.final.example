# ===== Secrets / cloud access =====
YANDEX_CLOUD_API_KEY=replace_me
YANDEX_CLOUD_FOLDER=b1g80c8c8v3gh72ahsi7
YANDEX_CLOUD_MODEL=yandexgpt-5-lite/latest
YANDEX_EMBEDDING_MODEL=text-search-query/latest
YANDEX_CLOUD_MAX_TOKENS=1200

# ===== Web defaults (UI baseline) =====
WEB_DEFAULT_TOP_K=12
WEB_DEFAULT_OFFICIAL_ONLY=true
WEB_DEFAULT_USE_LLM=true
WEB_DEFAULT_LLM_BACKEND=yandex_openai
WEB_DEFAULT_EMBEDDINGS_RERANK=true
WEB_DEFAULT_EMBEDDINGS_TOP_N=80
WEB_DEFAULT_SHOW_REASONING=true
WEB_DEFAULT_MULTI_STEP=true
WEB_DEFAULT_ANSWER_MODE=full
WEB_DEFAULT_NORM_QUOTE=true
WEB_SERVER_NAME=127.0.0.1
WEB_SERVER_PORT=7860

# ===== L2 answer cache (SQLite, survives restart) =====
ANSWER_CACHE_ENABLED=true
ANSWER_CACHE_TTL_SEC=604800
ANSWER_CACHE_MAX_ENTRIES=5000
RETRIEVAL_CACHE_ENABLED=true
RETRIEVAL_CACHE_TTL_SEC=259200
RETRIEVAL_CACHE_MAX_ENTRIES=10000

# ===== Post-retrieval hierarchy (neighbor / short article expansion) =====
# After TF-IDF + embeddings, подтягиваются соседние чанки (та же статья или тот же документ).
RAG_HIERARCHY_NEIGHBOR_HOPS=2
RAG_HIERARCHY_MAX_EXTRA=14
RAG_HIERARCHY_SMALL_ARTICLE_MAX_PARTS=4

# ===== Parent -> child retrieval (before LLM) =====
RAG_PARENT_TOP_N=5
RAG_PARENT_CHILD_MAX_EXTRA=12
RAG_PARENT_CHILD_WINDOW=2
RAG_PARENT_CHILD_FULL_PARTS=5
